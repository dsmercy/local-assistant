# ── Ollama ─────────────────────────────────────────────────────────────────
OLLAMA_ENDPOINT=http://localhost:11434
OLLAMA_MODEL_NAME=qwen2.5-coder:14b
OLLAMA_TIMEOUT_SECONDS=120

# ── Agent ──────────────────────────────────────────────────────────────────
AGENT_MAX_TOOL_CALL_DEPTH=10
AGENT_STUCK_DETECTION_WINDOW=3

# ── RAG ────────────────────────────────────────────────────────────────────
RAG_CHROMA_DB_PATH=./chroma_db
RAG_INSTRUCTIONS_DIR=./context_store/instructions
RAG_CODEBASE_DIR=./context_store/codebase
RAG_SAMPLES_DIR=./context_store/samples
RAG_EMBED_MODEL=nomic-embed-text
RAG_INSTRUCTIONS_CHUNK_SIZE=512
RAG_CODEBASE_CHUNK_SIZE=1024
RAG_SAMPLES_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=64
RAG_RETRIEVAL_K=5

# ── Server ─────────────────────────────────────────────────────────────────
SERVER_HOST=127.0.0.1
SERVER_PORT=8765
